DATABASE_URL="postgresql://forever:forever_dev@localhost:5433/forever?schema=public"

# MinIO (S3-compatible) - local development
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="forever-uploads"
S3_REGION="us-east-1"

# Auth.js
AUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email — SMTP connection string. If unset, falls back to Mailhog (localhost:1025)
# EMAIL_SERVER="smtp://user:pass@email-smtp.us-east-1.amazonaws.com:587"
FROM_EMAIL="noreply@yourdomain.com"

# Admin - email address of the site admin
ADMIN_EMAIL="admin@yourdomain.com"
