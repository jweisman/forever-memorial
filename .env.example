# ─── Database ───────────────────────────────────────────────────────────────
# Local: Docker Compose Postgres on port 5433
# Production: managed Postgres connection string (SSL is auto-enabled in production)
DATABASE_URL="postgresql://forever:forever_dev@localhost:5433/forever?schema=public"

# ─── S3 / Object Storage ───────────────────────────────────────────────────
# Local: MinIO via Docker Compose
# Production: AWS S3 — omit S3_ENDPOINT to use real S3, or use IAM role credentials
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="forever-uploads"
S3_REGION="us-east-1"

# ─── Auth.js ───────────────────────────────────────────────────────────────
# AUTH_URL: must match your deployment domain in production
# AUTH_SECRET: generate with `openssl rand -base64 32`
AUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# ─── Google OAuth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Email ─────────────────────────────────────────────────────────────────
# SMTP connection string. Required in production (e.g. SES SMTP).
# If unset in development, falls back to Mailhog on localhost:1025.
# EMAIL_SERVER="smtp://user:pass@email-smtp.us-east-1.amazonaws.com:587"
FROM_EMAIL="noreply@yourdomain.com"

# ─── Admin ─────────────────────────────────────────────────────────────────
# Users matching this email are auto-promoted to ADMIN role on sign-in
ADMIN_EMAIL="admin@yourdomain.com"

# ─── PDF Generation ─────────────────────────────────────────────────────────
# On macOS, Chrome at the default path is used automatically.
# Set this if Chrome is installed elsewhere, or on Linux without @sparticuz/chromium.
# On Vercel, @sparticuz/chromium handles the executable automatically.
# PUPPETEER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
