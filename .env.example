# ─── Database ───────────────────────────────────────────────────────────────
# Local: Docker Compose Postgres on port 5433
# Production: managed Postgres connection string (SSL is auto-enabled in production)
DATABASE_URL="postgresql://forever:forever_dev@localhost:5433/forever?schema=public"

# ─── S3 / Object Storage ───────────────────────────────────────────────────
# Local: MinIO via Docker Compose
# Production: AWS S3 — omit S3_ENDPOINT to use real S3, or use IAM role credentials
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="forever-uploads"
S3_REGION="us-east-1"

# ─── Auth.js ───────────────────────────────────────────────────────────────
# AUTH_URL: must match your deployment domain in production
# AUTH_SECRET: generate with `openssl rand -base64 32`
AUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# ─── Google OAuth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Email ─────────────────────────────────────────────────────────────────
# SMTP connection string. Required in production (e.g. SES SMTP).
# If unset in development, falls back to Mailhog on localhost:1025.
# EMAIL_SERVER="smtp://user:pass@email-smtp.us-east-1.amazonaws.com:587"
FROM_EMAIL="noreply@yourdomain.com"
# Optional: inject a custom header into every outgoing email (e.g. SES configuration set)
# EMAIL_CUSTOM_HEADER="X-SES-CONFIGURATION-SET: smtp-logging"

# ─── Admin ─────────────────────────────────────────────────────────────────
# Users matching these emails are auto-promoted to ADMIN role on sign-in.
# Supports a comma-separated list for multiple admins.
ADMIN_EMAIL="admin@yourdomain.com,other@yourdomain.com"

# ─── Contact Form ─────────────────────────────────────────────────────────
# Email address that receives contact form submissions.
CONTACT_EMAIL="leolamforever@gmail.com"
# Cloudflare Turnstile CAPTCHA (optional — form works without it, using honeypot only).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x..."
# TURNSTILE_SECRET_KEY="0x..."

# ─── Sentry (Error Tracking) ────────────────────────────────────────────────
# Get your DSN from: sentry.io → Project Settings → Client Keys
# Set both to the same DSN value. NEXT_PUBLIC_ prefix is required for browser capture.
# Leave unset in development to disable Sentry entirely.
# SENTRY_DSN="https://xxx@xxx.sentry.io/xxx"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.sentry.io/xxx"
#
# Optional — required only for uploading source maps (better stack traces in Sentry):
# SENTRY_AUTH_TOKEN="sntrys_..."   # sentry.io → Settings → Auth Tokens
# SENTRY_ORG="your-org-slug"
# SENTRY_PROJECT="your-project-slug"
