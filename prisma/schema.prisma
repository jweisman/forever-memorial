generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum MemoryStatus {
  PENDING
  ACCEPTED
  IGNORED
  RETURNED
}

enum MediaType {
  IMAGE
  VIDEO
}

model User {
  id        String   @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  avatar        String?
  role      Role     @default(USER)
  disabled  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memorials         Memorial[]
  submittedMemories Memory[]
  accounts          Account[]
  sessions          Session[]
  follows           MemorialFollow[]

  @@map("users")
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Memorial {
  id              String    @id @default(cuid())
  slug            String    @unique
  ownerId         String
  name            String
  additionalName  String?
  memorialPicture String?
  birthday        DateTime?
  placeOfBirth    String?
  dateOfDeath     DateTime
  placeOfDeath    String?
  funeralInfo     String?
  survivedBy      String?
  lifeStory        String?
  deathAfterSunset Boolean   @default(false)
  disabled         Boolean   @default(false)
  projects         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  owner    User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  albums   Album[]
  eulogies Eulogy[]
  memories Memory[]
  links    MemorialLink[]
  followers MemorialFollow[]

  @@index([name])
  @@map("memorials")
}

model Album {
  id         String   @id @default(cuid())
  memorialId String
  name       String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  images   Image[]

  @@map("albums")
}

model Image {
  id        String    @id @default(cuid())
  albumId   String
  s3Key     String
  caption   String?
  order     Int       @default(0)
  mediaType MediaType @default(IMAGE)
  createdAt DateTime  @default(now())

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@map("images")
}

model Eulogy {
  id          String   @id @default(cuid())
  memorialId  String
  text        String
  deliveredBy String
  relation    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  images   EulogyImage[]

  @@map("eulogies")
}

model Memory {
  id            String       @id @default(cuid())
  memorialId    String
  submitterId   String
  name          String
  withholdName  Boolean      @default(false)
  relation      String?
  text          String
  status        MemoryStatus @default(PENDING)
  returnMessage String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  memorial  Memorial      @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  submitter User          @relation(fields: [submitterId], references: [id], onDelete: Cascade)
  images    MemoryImage[]

  @@map("memories")
}

model MemorialLink {
  id          String   @id @default(cuid())
  memorialId  String
  url         String
  title       String
  description String?
  imageUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)

  @@map("memorial_links")
}

model MemorialFollow {
  userId     String
  memorialId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memorial Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)

  @@id([userId, memorialId])
  @@map("memorial_follows")
}

model MemoryImage {
  id        String    @id @default(cuid())
  memoryId  String
  s3Key     String
  caption   String?
  mediaType MediaType @default(IMAGE)
  createdAt DateTime  @default(now())

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@map("memory_images")
}

model EulogyImage {
  id        String    @id @default(cuid())
  eulogyId  String
  s3Key     String
  caption   String?
  mediaType MediaType @default(IMAGE)
  createdAt DateTime  @default(now())

  eulogy Eulogy @relation(fields: [eulogyId], references: [id], onDelete: Cascade)

  @@map("eulogy_images")
}
